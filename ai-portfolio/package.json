{
  "name": "ai-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate-sitemap": "next-sitemap --config next-sitemap.config.js",
    "postbuild": "npm run generate-sitemap",
    "schema-test": "npx structured-data-testing-tool --url https://www.harknessai.nz",
    "lighthouse": "lighthouse https://www.harknessai.nz --output html --output-path ./lighthouse-report.html --view --preset=desktop --throttling.cpuSlowdownMultiplier=2",
    "lighthouse:ci": "node lighthouse.js"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@types/react-helmet": "^6.1.11",
    "@types/react-router-dom": "^5.3.3",
    "@vercel/analytics": "^1.5.0",
    "framer-motion": "^12.4.10",
    "openai": "^4.87.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-helmet-async": "^2.0.5",
    "react-icons": "^4.12.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.21.0",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.21.0",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@vitejs/plugin-react": "^4.3.4",
    "chrome-launcher": "^1.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "lighthouse": "^11.5.0",
    "next-sitemap": "^4.2.3",
    "structured-data-testing-tool": "^4.5.0",
    "transform-react-pure-class-components": "^1.0.2",
    "transform-react-remove-prop-types": "^0.4.24",
    "typescript": "~5.0.2",
    "vite": "^4.4.5"
  }
}
